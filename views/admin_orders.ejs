<!doctype html><html><head><title>Pedidos</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><div class="container"><h1>Pedidos</h1><table><tr><th>ID</th><th>Cliente</th><th>Serviço</th><th>Qtd</th><th>Valor</th><th>Status</th><th>Fornecedor</th><th>Ação</th></tr><% orders.forEach(o=>{ %><tr><td>#<%=o.id%></td><td><%=o.user_name%></td><td><%=o.service_name%><br><span class="muted"><%=o.link%></span><% if(o.error){ %><br><span class="alert"><%=o.error%></span><% } %></td><td><%=o.quantity%></td><td><%=money(o.charge)%></td><td><%=o.status%></td><td><%=o.provider_order_id||'-'%></td><td><form method="post" action="/admin/order/<%=o.id%>/status"><select name="status"><option>pending</option><option>processing</option><option>sent</option><option>completed</option><option>manual_review</option><option>canceled</option></select><button>OK</button></form></td></tr><% }) %></table></div></body></html>
