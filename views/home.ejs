<!doctype html><html><head><title>SMM Pro</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><section class="hero"><div><h1>Venda serviços digitais com saldo, painel e entrega automática.</h1><p>Plataforma pronta para vender serviços de marketing social com margem, revendedores, histórico e painel administrativo.</p><a class="btn" href="/register">Começar agora</a></div><div class="card"><h2>Como funciona</h2><p>1. Cliente cria conta<br>2. Adiciona saldo via Pix<br>3. Faz pedido<br>4. Sistema envia para o fornecedor SMM</p><p class="muted">Configure os IDs reais dos serviços no painel admin.</p></div></section><h2 class="container">Serviços disponíveis</h2><div class="grid"><% services.forEach(s=>{ %><div class="card"><span class="badge"><%=s.platform%></span><h3><%=s.name%></h3><p class="muted"><%=s.category%> • Min <%=s.min_qty%> / Max <%=s.max_qty%></p><div class="price"><%=money(s.price_per_1000)%> / 1000</div><p><%=s.description%></p><a class="btn" href="/order/<%=s.id%>">Comprar</a></div><% }) %></div></body></html>
