<!doctype html><html><head><title>Recargas</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><div class="container"><h1>Recargas Pix</h1><table><tr><th>ID</th><th>Cliente</th><th>Valor</th><th>Status</th><th>Comprovante</th><th>Ações</th></tr><% deposits.forEach(d=>{ %><tr><td>#<%=d.id%></td><td><%=d.user_name%><br><span class="muted"><%=d.email%></span></td><td><%=money(d.amount)%></td><td><%=d.status%></td><td><%=d.proof||'-'%></td><td><% if(d.status==='pending'){ %><form method="post" action="/admin/deposit/<%=d.id%>/approve" style="display:inline"><button>Aprovar</button></form><form method="post" action="/admin/deposit/<%=d.id%>/reject" style="display:inline"><button class="secondary">Recusar</button></form><% } %></td></tr><% }) %></table></div></body></html>
