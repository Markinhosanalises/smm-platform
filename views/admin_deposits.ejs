<!doctype html><html lang="pt-BR"><head><title>Recargas | Fênix Social</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %>
<main class="dashboard"><div class="container"><div class="dash-hero"><div><span class="tag">Admin</span><h1>Recargas Pix</h1><p class="muted">Aprove ou recuse solicitações de saldo.</p></div><a class="btn-outline" href="/admin">Voltar</a></div>
<div class="card table-card"><div class="table-wrap"><table><tr><th>ID</th><th>Cliente</th><th>Valor</th><th>Status</th><th>Comprovante</th><th>Ações</th></tr><% deposits.forEach(d=>{ %><tr><td>#<%=d.id%></td><td><%=d.user_name%><br><span class="muted"><%=d.email%></span></td><td><%=money(d.amount)%></td><td><span class="status-badge <%=d.status%>"><%=d.status%></span></td><td><%=d.proof||'-'%></td><td><% if(d.status==='pending'){ %><form method="post" action="/admin/deposit/<%=d.id%>/approve" style="display:inline"><button>Aprovar</button></form><form method="post" action="/admin/deposit/<%=d.id%>/reject" style="display:inline"><button class="secondary">Recusar</button></form><% } %></td></tr><% }) %></table></div></div>
</div></main></body></html>
