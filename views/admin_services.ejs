<!doctype html><html><head><title>Serviços</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><div class="container"><h1>Serviços</h1><div class="card"><h2>Novo serviço</h2><form method="post" action="/admin/services"><input name="name" placeholder="Nome" required><input name="provider_service_id" placeholder="ID do fornecedor"><input name="platform" placeholder="Plataforma" required><input name="category" placeholder="Categoria" required><input name="min_qty" type="number" placeholder="Mínimo" required><input name="max_qty" type="number" placeholder="Máximo" required><input name="cost_per_1000" type="number" step="0.01" placeholder="Custo por 1000" required><input name="price_per_1000" type="number" step="0.01" placeholder="Preço por 1000" required><textarea name="description" placeholder="Descrição"></textarea><label><input type="checkbox" name="active" checked style="width:auto"> Ativo</label><button>Criar serviço</button></form></div><% services.forEach(s=>{ %><div class="card" style="margin-top:14px"><form method="post" action="/admin/service/<%=s.id%>"><h3>#<%=s.id%> <%=s.name%></h3><input name="name" value="<%=s.name%>"><input name="provider_service_id" value="<%=s.provider_service_id||''%>" placeholder="ID fornecedor"><input name="platform" value="<%=s.platform%>"><input name="category" value="<%=s.category%>"><input name="min_qty" type="number" value="<%=s.min_qty%>"><input name="max_qty" type="number" value="<%=s.max_qty%>"><input name="cost_per_1000" type="number" step="0.01" value="<%=s.cost_per_1000%>"><input name="price_per_1000" type="number" step="0.01" value="<%=s.price_per_1000%>"><textarea name="description"><%=s.description%></textarea><label><input type="checkbox" name="active" <%=s.active?'checked':''%> style="width:auto"> Ativo</label><button>Salvar</button></form></div><% }) %></div></body></html>
