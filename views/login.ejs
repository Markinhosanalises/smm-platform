<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Entrar - Fênix Social</title>
<link rel="stylesheet" href="/style.css">
</head>

<body class="auth-page">

<div class="auth-wrapper">

  <div class="auth-left">
    <span class="tag">ACESSO AO PAINEL</span>
    <h1>Bem-vindo de volta à <span class="highlight">Fênix Social</span></h1>
    <p>
      Entre na sua conta para acompanhar solicitações, saldo, histórico e gerenciar sua operação de forma simples.
    </p>

    <div class="auth-benefits">
      <div>✔ Painel moderno e organizado</div>
      <div>✔ Controle total das solicitações</div>
      <div>✔ Histórico de recargas e pedidos</div>
      <div>✔ Área exclusiva para revendedores</div>
    </div>
  </div>

  <div class="auth-card">
    <h2>Entrar</h2>
    <p>Acesse sua conta</p>

    <% if(error){ %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form method="POST">
      <label>E-mail</label>
      <input type="email" name="email" placeholder="Digite seu e-mail" required>

      <label>Senha</label>
      <input type="password" name="password" placeholder="Digite sua senha" required>

      <button class="btn-primary" type="submit">Entrar</button>
    </form>

    <div class="auth-footer">
      <p>Não possui conta?</p>
      <a href="/register">Criar conta</a>
    </div>
  </div>

</div>

</body>
</html>
