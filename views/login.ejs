<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Entrar | Fênix Social</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
  <div class="auth-wrapper">
    <div class="auth-left">
      <span class="tag">Acesso ao painel</span>
      <h1>Bem-vindo de volta à <span class="highlight">Fênix Social</span></h1>
      <p>Entre para acompanhar solicitações, saldo, recargas, histórico e suporte em um painel moderno.</p>
      <div class="auth-benefits">
        <div>✔ Painel moderno e organizado</div>
        <div>✔ Controle de saldo e histórico</div>
        <div>✔ Acompanhamento de solicitações</div>
        <div>✔ Área para clientes e revendedores</div>
      </div>
    </div>
    <div class="auth-card">
      <h2>Entrar</h2>
      <p>Informe seus dados para continuar.</p>
      <% if(error){ %><div class="alert"><%= error %></div><% } %>
      <form method="post">
        <label>E-mail</label>
        <input name="email" type="email" placeholder="seu@email.com" required>
        <label>Senha</label>
        <input name="password" type="password" placeholder="Sua senha" required>
        <button class="btn-primary" style="width:100%">Entrar</button>
      </form>
      <div class="auth-footer">Não possui conta? <a href="/register">Criar conta</a></div>
    </div>
  </div>
</body>
</html>
