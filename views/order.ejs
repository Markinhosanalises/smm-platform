<!doctype html><html><head><title>Comprar</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><div class="container form card"><h1><%=service.name%></h1><p class="muted">Min: <%=service.min_qty%> • Max: <%=service.max_qty%> • <%=money(service.price_per_1000)%>/1000</p><% if(error){ %><div class="alert"><%=error%></div><% } %><form method="post"><label>Link do perfil/publicação</label><input name="link" required placeholder="https://..."><label>Quantidade</label><input name="quantity" type="number" min="<%=service.min_qty%>" max="<%=service.max_qty%>" required><button>Confirmar pedido</button></form></div></body></html>
