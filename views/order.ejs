<!doctype html>
<html lang="pt-BR">
<head>
  <title>Solicitação | Fênix Social</title>
  <link rel="stylesheet" href="/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>
<body>
<%- include('partials_header') %>
<main class="dashboard">
  <div class="container">
    <div class="dash-hero">
      <div>
        <span class="tag"><%= service.platform %> • <%= service.category %></span>
        <h1><%= service.name %></h1>
        <p class="muted"><%= service.description || 'Informe os dados abaixo para abrir sua solicitação.' %></p>
      </div>
      <a class="btn-outline" href="/dashboard">Voltar</a>
    </div>

    <div class="card form">
      <h2>Nova solicitação</h2>
      <p class="muted">Min: <%= service.min_qty %> • Max: <%= service.max_qty %> • Valor: <%= money(service.price_per_1000) %>/1000</p>
      <% if(error){ %><div class="alert"><%= error %></div><% } %>
      <form method="post">
        <label>Link do perfil/publicação</label>
        <input name="link" required placeholder="https://...">
        <label>Quantidade</label>
        <input name="quantity" type="number" min="<%= service.min_qty %>" max="<%= service.max_qty %>" required>
        <button class="btn-primary">Confirmar solicitação</button>
      </form>
    </div>
  </div>
</main>
</body>
</html>
