<!doctype html>
<html lang="pt-BR">
<head>
  <title>Admin | Fênix Social</title>
  <link rel="stylesheet" href="/style.css">
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>

<body>
<%- include('partials_header') %>

<main class="dashboard">
  <div class="container">

    <div class="dash-hero">
      <div>
        <span class="tag">ADMINISTRATIVO</span>
        <h1>Painel administrativo</h1>
        <p class="muted">Controle usuários, serviços, pedidos, recargas e operação da plataforma.</p>
      </div>

      <a href="/dashboard" class="btn-primary">Ver painel do cliente</a>
    </div>

    <div class="adminbar">
      <a class="btn-outline" href="/admin/services">Serviços</a>
      <a class="btn-outline" href="/admin/orders">Pedidos</a>
      <a class="btn-outline" href="/admin/deposits">Recargas</a>
      <a class="btn-outline" href="/admin/users">Usuários</a>
    </div>

    <div class="stats">
      <div class="stat-card">
        <p>Usuários</p>
        <h2><%= stats.users %></h2>
      </div>

      <div class="stat-card">
        <p>Pedidos</p>
        <h2><%= stats.orders %></h2>
      </div>

      <div class="stat-card">
        <p>Faturado</p>
        <h2><%= money(stats.revenue) %></h2>
      </div>

      <div class="stat-card">
        <p>Lucro estimado</p>
        <h2><%= money(stats.profit) %></h2>
      </div>
    </div>

    <div class="dash-grid">

      <section class="card premium-card">
        <h2>Resumo da operação</h2>
        <p class="muted">Visão rápida do desempenho atual da plataforma.</p>

        <div class="summary-line">
          <span>Total de usuários</span>
          <strong><%= stats.users %></strong>
        </div>

        <div class="summary-line">
          <span>Total de pedidos</span>
          <strong><%= stats.orders %></strong>
        </div>

        <div class="summary-line">
          <span>Receita total</span>
          <strong><%= money(stats.revenue) %></strong>
        </div>

        <div class="summary-total">
          <span>Lucro estimado</span>
          <strong><%= money(stats.profit) %></strong>
        </div>
      </section>

      <section class="card premium-card">
        <h2>Fornecedor</h2>
        <p class="muted">Informações retornadas pela API integrada.</p>

        <pre class="code-box"><%= JSON.stringify(providerBalance, null, 2) %></pre>

        <a href="/balance" class="btn-outline">Ver saldo bruto</a>
      </section>

    </div>

  </div>
</main>

</body>
</html>
