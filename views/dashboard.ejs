<!doctype html><html><head><title>Dashboard</title><link rel="stylesheet" href="/style.css"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body><%- include('partials_header') %><div class="container"><h1>Minha conta</h1><div class="card"><h2>Saldo: <%=money(user.balance)%></h2><p><%=user.reseller?'Conta revendedor ativa: desconto aplicado automaticamente.':'Conta cliente padrão.'%></p></div><div class="grid" style="padding:20px 0"><div class="card"><h2>Adicionar saldo via Pix</h2><p class="muted">Faça o Pix e envie o comprovante/identificação. O admin aprova e o saldo entra.</p><form method="post" action="/deposit"><label>Valor</label><input name="amount" type="number" min="10" step="0.01" required><label>Comprovante ou observação</label><input name="proof" placeholder="Ex: Pix feito em nome de..."><button>Solicitar recarga</button></form></div><div class="card"><h2>Suporte</h2><form method="post" action="/ticket"><label>Assunto</label><input name="subject" required><label>Mensagem</label><textarea name="message" required></textarea><button>Abrir chamado</button></form></div></div><h2>Pedidos recentes</h2><table><tr><th>ID</th><th>Serviço</th><th>Qtd</th><th>Valor</th><th>Status</th></tr><% orders.forEach(o=>{ %><tr><td>#<%=o.id%></td><td><%=o.service_name%></td><td><%=o.quantity%></td><td><%=money(o.charge)%></td><td><%=o.status%></td></tr><% }) %></table><h2>Recargas</h2><table><tr><th>ID</th><th>Valor</th><th>Status</th><th>Data</th></tr><% deposits.forEach(d=>{ %><tr><td>#<%=d.id%></td><td><%=money(d.amount)%></td><td><%=d.status%></td><td><%=d.created_at%></td></tr><% }) %></table></div></body></html>
